  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'Presbyopia is an age-related vision condition in which the eyes gradually
    lose their ability to focus on nearby objects. It usually becomes noticeable
    after the age of 40 and is a natural part of the aging process. In presbyopia,
    the eye lens becomes less flexible over time, making it difficult for the eye
    to adjust its focus from distant to near objects. As a result, activities such
    as reading, writing, sewing, or using a mobile phone may become challenging.


    Presbyopia
    affects almost everyone as they grow older, regardless of whether they have previously
    had normal vision, myopia, or hyperopia. Although it cannot be prevented completely,
    it can be effectively managed with appropriate corrective measures. Early diagnosis
    and proper eye care can help individuals continue their daily activities comfortably.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
