      m_Calls: []
  m_text: '1. Blurred distance vision: Distant objects appear unclear while near
    objects remain clear.

    2. Difficulty seeing distant objects: Problems viewing
    road signs, classroom boards, or distant screens.

    3. Squinting: Frequent
    squinting to improve focus.

    4. Eye strain: Discomfort or tiredness after
    visual activities.

    5. Headaches: Often caused by prolonged effort to see
    distant objects clearly.

    6. Frequent blinking or eye rubbing: Common signs
    of visual discomfort.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
