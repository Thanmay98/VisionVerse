      m_Calls: []
  m_text: "1. Red-Green Color Blindness: \nThe most common type, causing difficulty
    distinguishing red and green shades.\n\n2. Blue-Yellow Color Blindness: \nDifficulty
    differentiating between blue and yellow colors.\n\n3. Complete Color Blindness
    (Achromatopsia): \nA rare condition where a person sees only shades of gray."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
