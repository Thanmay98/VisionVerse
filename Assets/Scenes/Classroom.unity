  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: '1. Elongated eyeball: The eyeball becomes longer than normal, causing
    light to focus in front of the retina.

    2. Excessive curvature of the cornea
    or lens: The cornea or lens bends light too strongly.

    3. Genetic factors:
    Children with one or both myopic parents have a higher risk of developing myopia.

    4.
    Excessive near work: Long hours of reading, writing, or screen use may contribute
    to myopia.

    5. Limited outdoor activities: Less exposure to natural light
    may increase the risk of myopia.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
