  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: '1. Difficulty distinguishing colors: Trouble telling certain colors apart,
    especially red and green.

    2. Confusion between color shades: Similar colors
    may appear identical.

    3. Problems identifying colored objects: Difficulty
    recognizing color-coded information.

    4. Reduced color perception: Colors
    may appear dull or less vivid.

    5. Difficulty in tasks involving color recognition:
    Such as reading charts, maps, or traffic signals.

    6. Unawareness of the
    condition: Many individuals do not realize they have color blindness until tested.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
